<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    SupabaseSecrets.example.plist
    -----------------------------
    1. Copy this file to:  loren/Config/SupabaseSecrets.plist
    2. Fill in your project's URL and anon (publishable) key.
    3. Keep SupabaseSecrets.plist OUT of version control. Add it to .gitignore.

    Find the values in your Supabase Dashboard:
      Project Settings → API → Project URL
      Project Settings → API → Project API keys → anon (public)

    DO NOT use the service_role key here. It bypasses RLS and must never ship
    inside a client app.
-->
<plist version="1.0">
<dict>
    <key>SUPABASE_URL</key>
    <string>https://YOUR-PROJECT-REF.supabase.co</string>
    <key>SUPABASE_ANON_KEY</key>
    <string>YOUR_ANON_OR_PUBLISHABLE_KEY</string>
</dict>
</plist>
